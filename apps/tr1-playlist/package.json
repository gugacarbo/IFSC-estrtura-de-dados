{
	"name": "tr1-playlist",
	"description": "Java Playlist com listas encadeadas",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"build": "javac src/main/java/playlist/*.java",
		"dev": "npm run build && java -cp src/main/java playlist.Main",
		"test": "echo 'Testes JUnit requerem configuracao manual (sem Maven)'",
		"lint": "javac -Xlint src/main/java/playlist/*.java",
		"typecheck": "javac -Xlint src/main/java/playlist/*.java",
		"format": "npm run format:java src/main/java/playlist/*.java",
		"clean": "del /s /q src\\main\\java\\playlist\\*.class 2>nul"
	}
}
